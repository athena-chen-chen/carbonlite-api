generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MembershipRole {
  OWNER
  ADMIN
  EDITOR
  VIEWER
}

enum FacilityType {
  OFFICE
  PLANT
  WAREHOUSE
  DATA_CENTER
  OTHER
}

enum AssetType {
  VEHICLE
  GENERATOR
  BOILER
  HVAC
  PRODUCTION_LINE
  SERVER_RACK
  OTHER
}

enum ActivityType {
  ELECTRICITY
  NATURAL_GAS
  DIESEL
  GASOLINE
  STEAM
  WATER
  WASTE
  AIR_TRAVEL
  HOTEL
  SHIPPING
  CUSTOM
}

enum RecordSourceType {
  MANUAL
  IMPORT
  API
  DOCUMENT_AI
}

enum FactorType {
  EMISSION
  ENERGY
  COST
  CUSTOM
}

enum MetricType {
  CARBON_EMISSION
  ENERGY_CONSUMPTION
  ENERGY_INTENSITY
  COST_ESTIMATE
  CUSTOM
}

enum ReportStatus {
  DRAFT
  GENERATED
  REVIEWED
  FINALIZED
}

enum DocumentType {
  UTILITY_BILL
  FUEL_INVOICE
  SPREADSHEET
  PDF
  IMAGE
  OTHER
}

enum DocumentStatus {
  UPLOADED
  PROCESSING
  PROCESSED
  IMPORTED
  FAILED
  NO_DATA_FOUND
  REVIEW_REQUIRED
  EXTRACTION_FAILED
  FILE_MISSING
}

enum AIJobType {
  EXTRACT_ACTIVITY_DATA
  GENERATE_REPORT_SUMMARY
  ASK_DATA_QUESTION
}

enum AIJobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum FeedbackType {
  BUG
  SUGGESTION
  QUESTION
  OTHER
}

enum FeedbackStatus {
  NEW
  REVIEWED
  CLOSED
}

enum UserRole {
  ADMIN
  USER
}

model User {
  id              String        @id @default(cuid())
  organizationId  String
  email           String        @unique
  passwordHash    String?
  firstName       String?
  lastName        String?
  role            UserRole      @default(USER)
  isActive        Boolean       @default(true)
  lastLoginAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  organization    Organization  @relation("OrganizationUsers", fields: [organizationId], references: [id], onDelete: Cascade)
  memberships     Membership[]
  createdReports  Report[]      @relation("ReportCreatedBy")
  createdDocs     Document[]    @relation("DocumentUploadedBy")
  createdAIJobs   AIJob[]       @relation("AIJobCreatedBy")
  auditLogs       AuditLog[]    @relation("AuditLogUser")
  activityEvents  UserActivityEvent[] @relation("UserActivityEventUser")

  @@index([organizationId])
}

model Organization {
  id              String             @id @default(cuid())
  name            String
  slug            String             @unique
  industry        String?
  country         String?
  provinceState   String?
  timezone        String?
  isActive        Boolean            @default(true)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  memberships     Membership[]
  users           User[]             @relation("OrganizationUsers")
  facilities      Facility[]
  factors         ConversionFactor[]
  reports         Report[]
  documents       Document[]
  aiJobs          AIJob[]
  auditLogs       AuditLog[]
  feedback        Feedback[]
  activityEvents  UserActivityEvent[]

  // 缺的就是这两个
  activityData    ActivityData[]
  metricResults   MetricResult[]
}

model Membership {
  id              String          @id @default(cuid())
  userId          String
  organizationId  String
  role            MembershipRole
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization    Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId])
}

model Facility {
  id              String          @id @default(cuid())
  organizationId  String
  name            String
  code            String?
  type            FacilityType    @default(OTHER)
  addressLine1    String?
  addressLine2    String?
  city            String?
  provinceState   String?
  country         String?
  postalCode      String?
  latitude        Float?
  longitude       Float?
  isActive        Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  organization    Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assets          Asset[]
  activityData    ActivityData[]
  metricResults   MetricResult[]
  reports         Report[]
  documents       Document[]

  @@index([organizationId])
}

model Asset {
  id              String          @id @default(cuid())
  facilityId      String
  name            String
  type            AssetType       @default(OTHER)
  serialNumber    String?
  manufacturer    String?
  model           String?
  notes           String?
  isActive        Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  facility        Facility        @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  activityData    ActivityData[]

  @@index([facilityId])
}

model ActivityData {
  id                String            @id @default(cuid())
  organizationId    String
  facilityId        String?
  assetId           String?
  documentId        String?
  activityType      ActivityType
  customTypeLabel   String?
  recordDate        DateTime
  dateEstimated     Boolean           @default(false)
  periodStart       DateTime?
  periodEnd         DateTime?
  quantity          Decimal           @db.Decimal(18, 4)
  unit              String
  sourceType        RecordSourceType
  sourceReference   String?
  sourceFileName    String?
  sourceDocumentId  String?
  importBatchId     String?
  notes             String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  organization      Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  facility          Facility?         @relation(fields: [facilityId], references: [id], onDelete: SetNull)
  asset             Asset?            @relation(fields: [assetId], references: [id], onDelete: SetNull)
  document          Document?         @relation(fields: [documentId], references: [id], onDelete: SetNull)
  metricResults     MetricResult[]

  @@index([organizationId])
  @@index([facilityId])
  @@index([assetId])
  @@index([documentId])
  @@index([activityType])
  @@index([recordDate])
}

model ConversionFactor {
  id                String          @id @default(cuid())
  organizationId    String?
  name              String
  type              FactorType
  activityType      ActivityType?
  jurisdiction      String?
  region            String?
  country           String?
  unit              String
  factorValue       Decimal         @db.Decimal(18, 8)
  resultUnit        String
  sourceName        String?
  sourceReference   String?
  sourceAuthority   String?
  sourceDocument    String?
  sourceYear        Int?
  sourceUrl         String?
  methodology       String?
  confidenceLevel   String?
  verified          Boolean         @default(false)
  notes             String?
  effectiveFrom     DateTime?
  effectiveTo       DateTime?
  isDefault         Boolean         @default(false)
  isSystemDefault   Boolean         @default(false)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  organization      Organization?   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  metricResults     MetricResult[]

  @@index([organizationId])
  @@index([type])
  @@index([activityType])
  @@index([jurisdiction])
  @@index([sourceYear])
  @@index([isSystemDefault])
}

model MetricResult {
  id                String            @id @default(cuid())
  organizationId    String
  facilityId        String?
  activityDataId    String?
  factorId          String?
  metricType        MetricType
  value             Decimal           @db.Decimal(18, 6)
  unit              String
  calculationDate   DateTime          @default(now())
  periodStart       DateTime?
  periodEnd         DateTime?
  detailsJson       Json?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  organization      Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  facility          Facility?         @relation(fields: [facilityId], references: [id], onDelete: SetNull)
  activityData      ActivityData?     @relation(fields: [activityDataId], references: [id], onDelete: SetNull)
  factor            ConversionFactor? @relation(fields: [factorId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([facilityId])
  @@index([activityDataId])
  @@index([factorId])
  @@index([metricType])
  @@index([periodStart, periodEnd])
}

model Report {
  id                String          @id @default(cuid())
  organizationId    String
  facilityId        String?
  title             String
  reportingYear     Int?
  periodStart       DateTime?
  periodEnd         DateTime?
  status            ReportStatus    @default(DRAFT)
  summary           String?
  contentMarkdown   String?
  generatedPdfUrl   String?
  createdById       String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  organization      Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  facility          Facility?       @relation(fields: [facilityId], references: [id], onDelete: SetNull)
  createdBy         User?           @relation("ReportCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  documents         Document[]
  aiJobs            AIJob[]

  @@index([organizationId])
  @@index([facilityId])
  @@index([status])
}

model Document {
  id                String          @id @default(cuid())
  organizationId    String
  facilityId        String?
  reportId          String?
  uploadedById      String?
  fileName          String
  fileUrl           String
  mimeType          String?
  fileSize          Int?
  fileHash          String?
  importedAt        DateTime?
  importBatchId     String?
  type              DocumentType    @default(OTHER)
  status            DocumentStatus  @default(UPLOADED)
  extractedText     String?
  extractedJson     Json?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  organization      Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  facility          Facility?       @relation(fields: [facilityId], references: [id], onDelete: SetNull)
  report            Report?         @relation(fields: [reportId], references: [id], onDelete: SetNull)
  uploadedBy        User?           @relation("DocumentUploadedBy", fields: [uploadedById], references: [id], onDelete: SetNull)
  activityData      ActivityData[]
  aiJobs            AIJob[]

  @@index([organizationId])
  @@index([organizationId, fileHash])
  @@index([facilityId])
  @@index([reportId])
  @@index([status])
}

model AIJob {
  id                String          @id @default(cuid())
  organizationId    String
  reportId          String?
  documentId        String?
  createdById       String?
  jobType           AIJobType
  status            AIJobStatus     @default(PENDING)
  prompt            String?
  inputJson         Json?
  outputText        String?
  outputJson        Json?
  errorMessage      String?
  startedAt         DateTime?
  completedAt       DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  organization      Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  report            Report?         @relation(fields: [reportId], references: [id], onDelete: SetNull)
  document          Document?       @relation(fields: [documentId], references: [id], onDelete: SetNull)
  createdBy         User?           @relation("AIJobCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([reportId])
  @@index([documentId])
  @@index([status])
  @@index([jobType])
}

model AuditLog {
  id                String          @id @default(cuid())
  organizationId    String?
  userId            String?
  action            String
  entityType        String
  entityId          String?
  description       String?
  oldValue          Json?
  newValue          Json?
  page              String?
  ipAddress         String?
  userAgent         String?
  createdAt         DateTime        @default(now())

  organization      Organization?   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user              User?           @relation("AuditLogUser", fields: [userId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([userId])
  @@index([action])
  @@index([entityType])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model Feedback {
  id              String          @id @default(cuid())
  type            FeedbackType
  intent          String          @db.Text
  message         String          @db.Text
  email           String?
  page            String?
  url             String?
  organizationId  String
  userAgent       String?
  status          FeedbackStatus  @default(NEW)
  createdAt       DateTime        @default(now())

  organization    Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([status])
  @@index([createdAt])
}

model UserActivityEvent {
  id             String   @id @default(cuid())
  organizationId String?
  userId         String?
  eventName      String
  page           String?
  url            String?
  entityType     String?
  entityId       String?
  metadata       Json?
  userAgent      String?
  createdAt      DateTime @default(now())

  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User?         @relation("UserActivityEventUser", fields: [userId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([userId])
  @@index([eventName])
  @@index([page])
  @@index([entityType, entityId])
  @@index([createdAt])
}
