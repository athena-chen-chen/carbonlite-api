{
  "compilerOptions": {
    "target": "es2022",
    "module": "es2022",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,

    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,

    "useDefineForClassFields": false,
    "outDir": "./dist"
  },
  "include": ["api/src/**/*.ts", "web/src/**/*.ts", "web/src/**/*.tsx"]
}
